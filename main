
"""
+Spike Prime Path Planner GUI
+Ported to Python 3.11 for full compatibility.
+Original version worked with older Python 3.x as well.
+2024, Sebi & ChatGPT
"""
 
import tkinter as tk
from tkinter import simpledialog, filedialog, messagebox
from PIL import Image, ImageTk
import math

# ---- CONFIGURATION ----
FIELD_WIDTH_CM = 236.2
FIELD_HEIGHT_CM = 114.3
ROBOT_UNIT_MULTIPLIER = 18.4  # 1 cm = 18.4 robot units
DEFAULT_SPEED = 300

# ---- GUI SETUP ----
root = tk.Tk()
root.title("Spike Prime Path Planner")

# ---- IMAGE LOAD ----
IMAGE_FILENAME = filedialog.askopenfilename(title="Select WRO Mat Image")
if not IMAGE_FILENAME:
    root.destroy()
    raise FileNotFoundError("No image selected!")

# Load and resize image to fill window, keep aspect
screen_width = root.winfo_screenwidth()
screen_height = root.winfo_screenheight()
max_width = int(screen_width * 0.85)
max_height = int(screen_height * 0.85)

img = Image.open(IMAGE_FILENAME)
if img.mode != "RGB":
    img = img.convert("RGB")
img_aspect = img.width / img.height
if (max_width / max_height) > img_aspect:
    resized_height = max_height
    resized_width = int(resized_height * img_aspect)
else:
    resized_width = max_width
    resized_height = int(resized_width / img_aspect)
img_resized = img.resize((resized_width, resized_height), Image.Resampling.LANCZOS)

# ---- CANVAS ----
canvas = tk.Canvas(root, width=resized_width, height=resized_height, bg='white')
canvas.pack(side=tk.RIGHT, expand=True, fill=tk.BOTH)

def draw_background_image():
    tk_img = ImageTk.PhotoImage(img_resized)
    canvas.img_ref = tk_img  # Keep reference alive
    canvas.create_image(0, 0, anchor='nw', image=tk_img)

root.after(100, draw_background_image)

# ---- STATE ----
actions = []  # ("arrow", start, end), ("gyro_reset", (x, y)), ("comment", (x, y), text)
current_tool = "arrow"
start_point = None
drawing_arrow = False
shift_pressed = False

# ---- UTILS ----
def distance(p1, p2):
    return math.sqrt((p1[0] - p2[0])**2 + (p1[1] - p2[1])**2)

def pixel_to_cm(px):
    scale_px_per_cm_x = resized_width / FIELD_WIDTH_CM
    scale_px_per_cm_y = resized_height / FIELD_HEIGHT_CM
    scale = (scale_px_per_cm_x + scale_px_per_cm_y) / 2
    return px / scale

def snap_angle(start, end, snap_angles=(0, 45, 90, 135, 180, 225, 270, 315), threshold=15, free_mode=False):
    dx = end[0] - start[0]
    dy = end[1] - start[1]
    if dx == 0 and dy == 0:
        return end, 0
    angle = math.degrees(math.atan2(dy, dx)) % 360
    snapped = angle
    if not free_mode:
        best = None
        min_diff = threshold
        for snap in snap_angles:
            diff = abs(angle - snap)
            if diff > 180:
                diff = 360 - diff
            if diff < min_diff:
                best = snap
                min_diff = diff
        if best is not None:
            snapped = best
    r = math.hypot(dx, dy)
    rad = math.radians(snapped)
    snapped_end = (int(start[0] + r * math.cos(rad)), int(start[1] + r * math.sin(rad)))
    return snapped_end, snapped

def vector_heading_deg(vec):
    return math.degrees(math.atan2(vec[1], vec[0])) % 360

# ---- DRAWING TOOLS ----
def set_tool(tool):
    global current_tool
    current_tool = tool

def on_shift(event):
    global shift_pressed
    shift_pressed = True

def on_shift_release(event):
    global shift_pressed
    shift_pressed = False

def on_click(event):
    global start_point, drawing_arrow
    if current_tool == "arrow":
        if actions and actions[-1][0] == "arrow":
            # Snap start to end of last arrow
            start_point = actions[-1][2]
        else:
            start_point = (event.x, event.y)
        drawing_arrow = True
    elif current_tool == "gyro_reset":
        canvas.create_oval(event.x-8, event.y-8, event.x+8, event.y+8, fill="#c2185b", outline="black", width=2)
        actions.append(("gyro_reset", (event.x, event.y)))
    elif current_tool == "comment":
        comment = simpledialog.askstring("Add Comment", "Enter your comment/instruction:")
        if comment:
            idx = len([a for a in actions if a[0] == "comment"]) + 1
            canvas.create_oval(event.x-8, event.y-8, event.x+8, event.y+8, fill="#fff59d", outline="black", width=2)
            canvas.create_text(event.x, event.y, text=str(idx), fill="black")
            actions.append(("comment", (event.x, event.y), comment))

def add_gyro_reset():
    # Add gyro reset at end of last arrow, if there is one
    last_arrow = None
    for act in reversed(actions):
        if act[0] == "arrow":
            last_arrow = act
            break
    if last_arrow:
        x, y = last_arrow[2]
        actions.append(("gyro_reset", (x, y)))
        redraw()
    else:
        messagebox.showinfo("No Arrow", "You must draw an arrow before placing a gyro reset.")

def on_drag(event):
    if current_tool == "arrow" and drawing_arrow and start_point:
        end = (event.x, event.y)
        free_mode = shift_pressed
        snapped_end, angle = snap_angle(start_point, end, free_mode=free_mode)
        canvas.delete("live_line")
        canvas.delete("live_label")
        canvas.create_line(start_point[0], start_point[1], snapped_end[0], snapped_end[1], arrow=tk.LAST, fill='#1976d2', width=3, tags="live_line")
        lbl_x = (start_point[0] + snapped_end[0]) // 2
        lbl_y = (start_point[1] + snapped_end[1]) // 2 - 20
        angle_str = f"{int(round(angle))}°"
        canvas.create_text(lbl_x, lbl_y, text=angle_str, fill='#1976d2', font=("Arial", 12, "bold"), tags="live_label")

def on_release(event):
    global start_point, drawing_arrow
    if current_tool == "arrow" and drawing_arrow and start_point:
        end = (event.x, event.y)
        free_mode = shift_pressed
        snapped_end, _ = snap_angle(start_point, end, free_mode=free_mode)
        canvas.create_line(start_point[0], start_point[1], snapped_end[0], snapped_end[1], arrow=tk.LAST, fill='green', width=3)
        actions.append(("arrow", start_point, snapped_end))
        start_point = None
        drawing_arrow = False
        canvas.delete("live_line")
        canvas.delete("live_label")

def undo():
    if actions:
        actions.pop()
        redraw()

def clear_all():
    actions.clear()
    redraw()

def redraw():
    canvas.delete("all")
    tk_img = ImageTk.PhotoImage(img_resized)
    canvas.img_ref = tk_img
    canvas.create_image(0, 0, anchor='nw', image=tk_img)
    for i, act in enumerate(actions):
        if act[0] == "arrow":
            canvas.create_line(act[1][0], act[1][1], act[2][0], act[2][1], arrow=tk.LAST, fill='green', width=3)
        elif act[0] == "gyro_reset":
            canvas.create_oval(act[1][0]-8, act[1][1]-8, act[1][0]+8, act[1][1]+8, fill="#c2185b", outline="black", width=2)
        elif act[0] == "comment":
            idx = len([a for a in actions[:i+1] if a[0] == "comment"])
            canvas.create_oval(act[1][0]-8, act[1][1]-8, act[1][0]+8, act[1][1]+8, fill="#fff59d", outline="black", width=2)
            canvas.create_text(act[1][0], act[1][1], text=str(idx), fill="black")

def export_commands():
    cmds = []
    warnings = []
    heading = 0.0

    def near(p1, p2, tol=12):
        return abs(p1[0]-p2[0]) < tol and abs(p1[1]-p2[1]) < tol

    reset_points = [a[1] for a in actions if a[0] == "gyro_reset"]
    comment_points = [(a[1], a[2]) for a in actions if a[0] == "comment"]

    arrow_actions = [a for a in actions if a[0] == "arrow"]

    for i, act in enumerate(arrow_actions):
        start, end = act[1], act[2]

        if any(near(start, rp) for rp in reset_points):
            cmds.append("Gyro_reset()")
            heading = 0.0

        vec = (end[0] - start[0], end[1] - start[1])
        target_heading = vector_heading_deg(vec)

        dist_px = distance(start, end)
        dist_cm = pixel_to_cm(dist_px)
        dist_units = dist_cm * ROBOT_UNIT_MULTIPLIER

        cmds.append(
            f"await fahren_gyro_grad_winkel({DEFAULT_SPEED}, {dist_units:.1f}, {int(round(target_heading))}) "
            f"# {dist_cm:.1f} cm"
        )
        heading = target_heading

        for point, text in comment_points:
            if near(point, end):
                cmds.append(f"# Comment: {text}")

        if i + 1 < len(arrow_actions):
            next_start = arrow_actions[i + 1][1]
            if not near(end, next_start):
                warnings.append(
                    f"# WARNING: Path break between arrow {i+1} end and arrow {i+2} start. "
                    f"Consider connecting them or adding reset/comment markers intentionally."
                )

    export_str = "\n".join(warnings + cmds)
    ExportWindow(root, export_str)

class ExportWindow(tk.Toplevel):
    def __init__(self, master, text):
        super().__init__(master)
        self.title("Exported Robot Program")
        text_widget = tk.Text(self, wrap="word", width=70, height=30)
        text_widget.insert("1.0", text)
        text_widget.pack()
        btn = tk.Button(self, text="Close", command=self.destroy)
        btn.pack()

# ---- SIDEBAR ----
sidebar = tk.Frame(root)
sidebar.pack(side=tk.LEFT, fill=tk.Y)

for text, tool in [("Draw Arrow", "arrow"), ("Add Comment", "comment")]:
    tk.Button(sidebar, text=text, command=lambda t=tool: set_tool(t)).pack(fill=tk.X, padx=4, pady=2)

btn_reset = tk.Button(sidebar, text="Place Gyro Reset", command=add_gyro_reset)
btn_reset.pack(fill=tk.X, padx=4, pady=2)

tk.Button(sidebar, text="Undo", command=undo).pack(fill=tk.X, padx=4, pady=2)
tk.Button(sidebar, text="Clear All", command=clear_all).pack(fill=tk.X, padx=4, pady=2)
tk.Button(sidebar, text="Export", command=export_commands).pack(fill=tk.X, padx=4, pady=8)

canvas.bind("<Button-1>", on_click)
canvas.bind("<ButtonRelease-1>", on_release)
canvas.bind("<B1-Motion>", on_drag)

root.bind("<Shift_L>", on_shift)
root.bind("<KeyRelease-Shift_L>", on_shift_release)
root.bind("<Shift_R>", on_shift)
root.bind("<KeyRelease-Shift_R>", on_shift_release)

root.state('zoomed')
root.mainloop()
 
